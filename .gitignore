# ── 数据文件（太大，不进 Git）──
data/*
!data/.gitkeep

# ── 输出文件（图片、模型等）──
output/*
!output/.gitkeep
results_bundle.tar.gz

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── 虚拟环境 ──
.venv/
venv/
env/

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── Jupyter ──
.ipynb_checkpoints/

# ── macOS ──
.DS_Store
._*

# ── 环境变量 ──
.env

# ── Docker ──
docker-compose.override.yml

# ── 临时文件 ──
*.tmp
*.log

# ── 项目引导文档（不推送）──
AGENTS.md

# ── 原始数据文件 ──
UserBehavior.csv
